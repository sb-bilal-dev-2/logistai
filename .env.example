# Database connection. Defaults to a local SQLite file.
# For PostgreSQL use e.g.: postgresql+psycopg://user:pass@localhost:5432/logistai
DATABASE_URL=sqlite:///logistai.db

# --- Request generator tuning ---
# Min/max gap between auto-generated requests, in seconds (1-10 minutes).
REQUEST_MIN_INTERVAL_SECONDS=60
REQUEST_MAX_INTERVAL_SECONDS=600

# --- Matching agent ---
# Top-N trucks the agent records per request.
MATCH_TOP_N=3
# Max distance (km) a truck can be from the loading point to still be considered.
MATCH_MAX_DISTANCE_KM=600

# --- Optional LLM reasoning layer (Anthropic Claude) ---
# If unset, the agent uses its deterministic geo-ranking only.
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8
# Set to 1 to ask the LLM to re-rank / explain the top candidates.
USE_LLM_RERANK=0

# --- Seeding ---
# Number of trucks to seed into `malumotlar` if the table is empty.
SEED_TRUCK_COUNT=120
