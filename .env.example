# Database connection. Defaults to a local SQLite file.
# For PostgreSQL use e.g.: postgresql+psycopg://user:pass@localhost:5432/logistai
DATABASE_URL=sqlite:///logistai.db

# --- Request generator tuning ---
# Min/max gap between auto-generated requests, in seconds (1-10 minutes).
REQUEST_MIN_INTERVAL_SECONDS=60
REQUEST_MAX_INTERVAL_SECONDS=600

# --- Matching agent ---
# Top-N trucks the agent records per request.
MATCH_TOP_N=3
# Max distance (km) a truck can be from the loading point to still be considered.
MATCH_MAX_DISTANCE_KM=600

# --- LLM re-rank layer (ON by default, local) ---
# LLM_PROVIDER selects the backend that re-ranks/explains the top candidates:
#   ollama -> a LOCALLY INSTALLED LLM via Ollama (DEFAULT; offline, no API key).
#             Falls back to geo order if the Ollama server isn't running.
#   none   -> deterministic geo-ranking only (no LLM at all)
#   claude -> Anthropic Claude (cloud API; needs ANTHROPIC_API_KEY)
LLM_PROVIDER=ollama

# Local LLM (Ollama). Install from https://ollama.com, then `ollama pull qwen2.5:0.5b`.
# NOTE: docker compose also reads .env, so OLLAMA_MODEL sets the model the
# docker-ollama stack pulls/uses too. Use a bigger model (e.g. llama3.2:3b) for
# better re-ranking quality.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b
LLM_TIMEOUT_SECONDS=120

# Cloud LLM (only used when LLM_PROVIDER=claude).
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8

# --- Seeding ---
# Number of trucks to seed into `malumotlar` if the table is empty.
SEED_TRUCK_COUNT=120
